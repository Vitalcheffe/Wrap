{
  "name": "@wrap/core",
  "version": "1.0.0",
  "description": "WRAP Core Runtime - Universal AI Agent Execution Engine",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": { "import": "./dist/index.mjs", "require": "./dist/index.js", "types": "./dist/index.d.ts" },
    "./sandbox": { "import": "./dist/sandbox.mjs", "require": "./dist/sandbox.js", "types": "./dist/sandbox.d.ts" },
    "./agent": { "import": "./dist/agent.mjs", "require": "./dist/agent.js", "types": "./dist/agent.d.ts" },
    "./tools": { "import": "./dist/tools.mjs", "require": "./dist/tools.js", "types": "./dist/tools.d.ts" },
    "./mcp": { "import": "./dist/mcp.mjs", "require": "./dist/mcp.js", "types": "./dist/mcp.d.ts" },
    "./safety": { "import": "./dist/safety.mjs", "require": "./dist/safety.js", "types": "./dist/safety.d.ts" }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src --ext .ts",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "eventemitter3": "^5.0.1",
    "uuid": "^9.0.0",
    "chalk": "^5.3.0",
    "zod": "^3.22.0",
    "@opentelemetry/api": "^1.7.0",
    "@opentelemetry/sdk-node": "^0.45.0",
    "isolated-vm": "^4.6.0",
    "ws": "^8.14.0",
    "dockerode": "^4.0.0"
  },
  "devDependencies": {
    "@types/uuid": "^9.0.0",
    "@types/ws": "^8.5.0",
    "@types/dockerode": "^3.3.0",
    "@types/node": "^20.10.0",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "keywords": ["ai", "agent", "sandbox", "runtime", "mcp", "llm"],
  "license": "MIT"
}
