# WRAP NEBULA Configuration
# Copy this file to .env and fill in your values

# === LLM Provider ===
# Choose one provider and set its API key

# Anthropic (Claude)
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI (GPT-4)
# OPENAI_API_KEY=sk-...

# Google (Gemini)
# GOOGLE_API_KEY=...

# Ollama (free, local — no key needed)
# Just install: curl -fsSL https://ollama.com/install.sh | sh
# Then: ollama pull llama3

# === Telegram ===
TELEGRAM_BOT_TOKEN=123456:ABC-DEF...
TELEGRAM_ALLOWED_USERS=

# === Discord (v8) ===
# DISCORD_BOT_TOKEN=...

# === Governor ===
GOVERNOR_ADDRESS=localhost:50051

# === Server ===
CORE_PORT=3777
CORE_HOST=0.0.0.0

# === VFS ===
VFS_ROOT=./sandbox
