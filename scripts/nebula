#!/usr/bin/env python3
"""WRAP NEBULA CLI"""
import sys, os, json, time, subprocess, getpass, urllib.request

NEBULA_DIR = os.path.expanduser('~/.nebula')
AUTH_FILE = os.path.join(NEBULA_DIR, 'auth-profiles.json')
CONFIG_FILE = os.path.join(NEBULA_DIR, 'config.yaml')
SOUL_FILE = os.path.join(NEBULA_DIR, 'SOUL.md')

G = '\033[32m'  # green
R = '\033[31m'  # red
Y = '\033[33m'  # yellow
C = '\033[36m'  # cyan
N = '\033[0m'   # reset

def banner():
    print(f'''
 ██╗    ██╗██████╗  █████╗ ██████╗
 ██║    ██║██╔══██╗██╔══██╗██╔══██╗
 ██║ █╗ ██║██████╔╝███████║██████╔╝
 ██║███╗██║██╔══██╗██╔══██║██╔═══╝
 ╚███╔███╔╝██║  ██║██║  ██║██║
  ╚══╝╚══╝ ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝

 NEBULA v8.0 by VitalCheffe
''')

# ─── Auth ────────────────────────────────────────────────────────────

def auth_load():
    try: return json.load(open(AUTH_FILE))
    except: return {'version': 1, 'profiles': {}}

def auth_save(store):
    os.makedirs(os.path.dirname(AUTH_FILE), exist_ok=True)
    json.dump(store, open(AUTH_FILE, 'w'), indent=2)

def cmd_auth_login(provider=None):
    if not provider:
        print('  Choose provider:')
        print('  1) anthropic (Claude)')
        print('  2) openai (GPT-4)')
        print('  3) ollama (local, free)')
        c = input('  Choice (1/2/3): ')
        provider = {'1': 'anthropic', '2': 'openai', '3': 'ollama'}.get(c)
        if not provider:
            print(f'  {R}Invalid choice{N}')
            return

    if provider == 'ollama':
        try:
            urllib.request.urlopen('http://localhost:11434/api/tags', timeout=3)
            store = auth_load()
            store['profiles']['ollama:default'] = {
                'type': 'api_key', 'provider': 'ollama', 'key': 'local', 'createdAt': int(time.time()*1000)
            }
            store.setdefault('lastGood', {})['ollama'] = 'default'
            auth_save(store)
            print(f'  {G}Saved ollama:default{N}')
        except:
            print(f'  {R}Ollama not running. Start with: ollama serve{N}')
    else:
        key = getpass.getpass('  Paste your API key: ')
        if not key:
            print('  No key entered')
            return
        store = auth_load()
        store['profiles'][f'{provider}:default'] = {
            'type': 'api_key', 'provider': provider, 'key': key, 'createdAt': int(time.time()*1000)
        }
        store.setdefault('lastGood', {})[provider] = 'default'
        auth_save(store)
        print(f'  {G}Saved {provider}:default{N}')

def cmd_auth_list():
    store = auth_load()
    profiles = store.get('profiles', {})
    if not profiles:
        print('  No profiles. Run: nebula auth login')
        return
    print(f'  {"Profile":<27} {"Type":<10} {"Added"}')
    print(f'  {"-------":<27} {"----":<10} {"-----"}')
    for pid, cred in profiles.items():
        ago = int((time.time() * 1000 - cred.get('createdAt', 0)) / 86400000)
        ago_str = f'{ago}d ago' if ago > 0 else 'just now'
        print(f'  {pid:<27} {cred.get("type", "?"):<10} {ago_str}')

def cmd_auth_logout(provider):
    if not provider:
        print('  Usage: nebula auth logout <provider>')
        return
    store = auth_load()
    removed = [k for k in list(store.get('profiles', {}).keys()) if k.startswith(f'{provider}:')]
    for k in removed:
        del store['profiles'][k]
    auth_save(store)
    if removed:
        print(f'  {G}Logged out from {", ".join(removed)}{N}')
    else:
        print(f'  No profiles for {provider}')

def cmd_auth_status():
    store = auth_load()
    profiles = store.get('profiles', {})
    if profiles:
        providers = set(v.get('provider', '?') for v in profiles.values())
        print(f'  {G}Auth: {len(profiles)} profile(s) — {", ".join(providers)}{N}')
    else:
        print(f'  {Y}Auth: not authenticated{N}')

# ─── Core commands ───────────────────────────────────────────────────

def cmd_help():
    print(f'''  {C}WRAP NEBULA — Zero Trust AI Agent Framework{N}

  Commands:
    init           Setup wizard
    start          Start the agent
    stop           Stop the agent
    status         Show status
    doctor         Health check
    auth login     Authenticate with a provider
    auth list      Show saved credentials
    auth logout    Remove a credential
    auth status    Show auth status
''')

def cmd_doctor():
    print(f'  {C}Health Check{N}')
    import platform
    print(f'  Node: {subprocess.getoutput("node --version").strip() or "not found"}')
    print(f'  Python: {platform.python_version()}')
    print(f'  Config: {"OK" if os.path.exists(CONFIG_FILE) else "MISSING"}')
    print(f'  SOUL: {"OK" if os.path.exists(SOUL_FILE) else "MISSING"}')
    cmd_auth_status()

def cmd_status():
    import signal
    try:
        subprocess.check_output(['pgrep', '-f', 'start-agent'], stderr=subprocess.DEVNULL)
        print(f'  {G}Running{N}')
    except:
        print(f'  {Y}Stopped{N}')
    if os.path.exists(CONFIG_FILE):
        with open(CONFIG_FILE) as f:
            print(f.read())

def cmd_init():
    print(f'  {C}Setup wizard{N}')
    print('  Run the interactive wizard:')
    print(f'  {Y}cd {NEBULA_DIR} && node -e "..."  (or use the web UI){N}')

# ─── Main ────────────────────────────────────────────────────────────

def main():
    args = sys.argv[1:]
    cmd = args[0] if args else 'help'

    if cmd == 'auth':
        sub = args[1] if len(args) > 1 else 'help'
        arg = args[2] if len(args) > 2 else None
        if sub == 'login': cmd_auth_login(arg)
        elif sub == 'list': cmd_auth_list()
        elif sub == 'logout': cmd_auth_logout(arg)
        elif sub == 'status': cmd_auth_status()
        elif sub == 'help': print('  Usage: nebula auth <login|list|logout|status>')
        else: print(f'  Unknown: auth {sub}')
    elif cmd == 'help' or cmd == '--help':
        banner()
        cmd_help()
    elif cmd == 'doctor':
        banner()
        cmd_doctor()
    elif cmd == 'status':
        cmd_status()
    elif cmd == 'init':
        banner()
        cmd_init()
    elif cmd == 'start':
        print('  Starting NEBULA...')
        subprocess.run(['npx', 'tsx', f'{NEBULA_DIR}/start-agent.ts'], cwd=NEBULA_DIR)
    elif cmd == 'stop':
        subprocess.run(['pkill', '-f', 'start-agent'], stderr=subprocess.DEVNULL)
        print('  Stopped')
    elif cmd == 'version' or cmd == '-v':
        print('NEBULA v8.0.0')
    else:
        print(f'  Unknown command: {cmd}')
        cmd_help()

if __name__ == '__main__':
    main()
