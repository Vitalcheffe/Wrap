#!/usr/bin/env bash
# WRAP NEBULA CLI
set -euo pipefail

WRAP_DIR="$(cd "$(dirname "$0")/.." && pwd)"
SOUL_FILE="$WRAP_DIR/skills/default/SOUL.md"
ENV_FILE="$WRAP_DIR/.env"

# Colors
CYAN='\033[36m'
GREEN='\033[32m'
RED='\033[31m'
YELLOW='\033[33m'
BOLD='\033[1m'
NC='\033[0m'

print_banner() {
  echo -e "${CYAN}"
  echo " ██╗    ██╗██████╗  █████╗ ██████╗ "
  echo " ██║    ██║██╔══██╗██╔══██╗██╔══██╗"
  echo " ██║ █╗ ██║██████╔╝███████║██████╔╝"
  echo " ██║███╗██║██╔══██╗██╔══██║██╔═══╝ "
  echo " ╚███╔███╔╝██║  ██║██║  ██║██║     "
  echo "  ╚══╝╚══╝ ╚═╝  ╚═╝╚═╝  ╚═╝╚═╝     "
  echo -e "${NC}"
  echo -e " ${BOLD}NEBULA v8.0${NC} by VitalCheffe"
  echo " github.com/Vitalcheffe/Wrap"
  echo ""
}

cmd_init() {
  print_banner
  echo -e "${CYAN}╔═══════════════════════════════════╗${NC}"
  echo -e "${CYAN}║    WRAP NEBULA — Setup Wizard     ║${NC}"
  echo -e "${CYAN}╚═══════════════════════════════════╝${NC}"
  echo ""

  read -p "$(echo -e "${YELLOW}?${NC} Agent name (default: Aria): ")" name
  name=${name:-Aria}

  echo ""
  echo "Choose your AI backend:"
  echo "  1) Ollama (free, local — recommended)"
  echo "  2) Claude (Anthropic API key)"
  echo "  3) GPT-4 (OpenAI API key)"
  read -p "$(echo -e "${YELLOW}?${NC} Choice (1/2/3, default: 1): ")" backend
  backend=${backend:-1}

  api_key=""
  model="llama3"
  case $backend in
    1)
      if ! command -v ollama &> /dev/null; then
        echo -e "\n${YELLOW}⚠ Ollama is not installed.${NC}"
        echo "Install from: https://ollama.com"
        echo "Then run: ollama pull llama3"
      fi
      ;;
    2)
      read -sp "$(echo -e "${YELLOW}?${NC} Anthropic API key: ")" api_key
      echo ""
      model="claude-3-5-sonnet-20241022"
      ;;
    3)
      read -sp "$(echo -e "${YELLOW}?${NC} OpenAI API key: ")" api_key
      echo ""
      model="gpt-4o"
      ;;
  esac

  echo ""
  read -p "$(echo -e "${YELLOW}?${NC} Enable Telegram? (y/N): ")" telegram
  telegram=${telegram:-n}
  tg_token=""
  if [[ "$telegram" =~ ^[Yy]$ ]]; then
    read -sp "$(echo -e "${YELLOW}?${NC} Telegram bot token: ")" tg_token
    echo ""
  fi

  # Create SOUL.md
  mkdir -p "$(dirname "$SOUL_FILE")"
  cat > "$SOUL_FILE" << EOF
# SOUL.md

Name: $name
Personality: Curious and direct assistant

Skills enabled:
- web.search
- files.read
- files.write
- files.list
- code.run
- reminder.set
- reminder.list

Rules:
- Never share API keys
- Ask before deleting files
- Keep answers concise
EOF

  # Create .env
  cat > "$ENV_FILE" << EOF
# WRAP NEBULA Configuration
WRAP_SECRET_KEY=$(openssl rand -hex 32 2>/dev/null || echo "change-me-$(date +%s)")

# AI Model
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=$model
${api_key:+ANTHROPIC_API_KEY=$api_key}
${api_key:+OPENAI_API_KEY=$api_key}

# Telegram
${tg_token:+TELEGRAM_BOT_TOKEN=$tg_token}

# Paths
WRAP_FILES_DIR=$HOME/wrap-files
WRAP_DATA_DIR=$HOME/.wrap

# Ports
CORE_PORT=3001
WAR_ROOM_PORT=3000
EOF

  mkdir -p "$HOME/wrap-files"

  echo ""
  echo -e "${GREEN}✓${NC} Created skills/default/SOUL.md"
  echo -e "${GREEN}✓${NC} Created .env"
  echo -e "${GREEN}✓${NC} Agent \"$name\" is ready."
  echo ""
  echo -e "Run: ${BOLD}nebula start${NC}"
}

cmd_start() {
  print_banner

  # Check .env
  if [[ ! -f "$ENV_FILE" ]]; then
    echo -e "${RED}✗${NC} No .env file found."
    echo "Run: nebula init"
    exit 1
  fi

  source "$ENV_FILE"

  echo -e "[...] Loading SOUL.md..."
  if [[ -f "$SOUL_FILE" ]]; then
    name=$(grep -i "^Name:" "$SOUL_FILE" | head -1 | sed 's/^[Nn]ame:[[:space:]]*//')
    echo -e "${GREEN}✓${NC} $name loaded"
  else
    echo -e "${YELLOW}⚠${NC} No SOUL.md, using defaults"
    name="NEBULA"
  fi

  echo -e "[...] Connecting to Ollama..."
  if curl -s --max-time 3 "http://localhost:11434/api/tags" > /dev/null 2>&1; then
    echo -e "${GREEN}✓${NC} Ollama connected (${OLLAMA_MODEL:-llama3})"
  else
    echo -e "${RED}✗${NC} Ollama not running. Start with: ollama serve"
    exit 1
  fi

  echo -e "[...] Initializing memory..."
  mkdir -p "${WRAP_DATA_DIR:-$HOME/.wrap}"
  echo -e "${GREEN}✓${NC} Memory ready"

  if [[ -n "${TELEGRAM_BOT_TOKEN:-}" ]]; then
    echo -e "[...] Starting Telegram bot..."
    echo -e "${GREEN}✓${NC} Telegram bot ready"
  fi

  echo ""
  echo -e "${CYAN}────────────────────────────────────────────${NC}"
  echo -e "${BOLD}$name is live.${NC} Open a chat to interact."
  echo -e "${CYAN}────────────────────────────────────────────${NC}"
  echo ""

  # Start the agent
  cd "$WRAP_DIR"
  npx tsx scripts/start.ts
}

cmd_status() {
  print_banner
  if [[ -f "$ENV_FILE" ]]; then
    source "$ENV_FILE"
    echo "Configuration:"
    echo "  Model: ${OLLAMA_MODEL:-llama3}"
    echo "  Files dir: ${WRAP_FILES_DIR:-$HOME/wrap-files}"
    echo "  Data dir: ${WRAP_DATA_DIR:-$HOME/.wrap}"
    if [[ -n "${TELEGRAM_BOT_TOKEN:-}" ]]; then
      echo "  Telegram: configured"
    else
      echo "  Telegram: not configured"
    fi
  else
    echo "Not configured. Run: nebula init"
  fi
}

# Main
case "${1:-help}" in
  init)    cmd_init ;;
  start)   cmd_start ;;
  status)  cmd_status ;;
  help|*)
    print_banner
    echo "Usage: nebula <command>"
    echo ""
    echo "Commands:"
    echo "  init     Interactive setup wizard"
    echo "  start    Start the agent"
    echo "  status   Show configuration"
    echo "  help     Show this help"
    ;;
esac
